def cost_function(fret_distance, string_distance,octave_difference, fret, string, disliked_string_list, preferred_fret):
    distance_from_preferred_fret = abs(preferred_fret - fret)
    if string in disliked_string_list:
        disliked_string_penalty = 1.5
    else:
        disliked_string_penalty = 0
    cost = (1.5 * string_distance) + (1 * fret_distance) + (1.5 * octave_difference) + 0.2 * distance_from_preferred_fret + disliked_string_penalty 
    if fret_distance == string_distance == 1: #rewards 1 by 1 diagonal moves
        cost -= 1
    if string_distance == 0: #rewards lack of string changes
        cost -= 1
    if string_distance >= 2:
        cost += ((string_distance -1) * 0.5)
    
    
    return cost

def greedy_algorithm(note, disliked_string_list, preferred_fret):
    start_time = time.perf_counter()
    tab_solution = []
    current_fret_position = (0, 0)
    for x in range(len(note[0].fret_positions)):#determines and chooses lowest string as starting point
        if current_fret_position[0] <= note[0].fret_positions[x][0]:
            current_fret_position = note[0].fret_positions[x]


    tab_solution.append(current_fret_position)
    cost_list = []      
    for current in range(1, len(note)):
        lowest_cost = 9999999999999999999999999999
        best_position = 0
        fret_position_index = 0 #incremented wjhile looping through fret positions in order to keep track of fret_position indexes without runing into posiibille issue if duplicate positions available. also costs less computationally
        for fret_position in note[current].fret_positions:
            fret_distance = abs(fret_position[1] - current_fret_position[1])
            fret = fret_position[1]
            string = fret_position[0]
            string_distance = abs(fret_position[0] - current_fret_position[0])
            octave_difference = note[current].octave_differences[fret_position_index]
            current_cost = cost_function(fret_distance, string_distance, octave_difference, fret, string, disliked_string_list, preferred_fret)
            fret_position_index += 1
            if  current_cost < lowest_cost:
                lowest_cost = current_cost
                best_position = fret_position
        current_fret_position = best_position
        tab_solution.append(current_fret_position)
        end_time = time.perf_counter()
    greedy_time = end_time - start_time
    return tab_solution, greedy_time

def dynamic_programming(note, disliked_string_list, preferred_fret):
    start_time = time.perf_counter()
    position_paths = {

}#stores current position as key and previous way of getting there as entry
    recent_moves = []
    for position in note[0].fret_positions:
        cost = 0
        key = (position, 0)
        position_paths[key] = "None"
        recent_moves.append((position, cost))#list of tuples containing previous note positions and costs to get there

    for current in range(1, len(note)):
        fret_position_index = 0
        temp_move_list = []
        for position in note[current].fret_positions:
            current_best_cost = float("inf")
            for move in recent_moves:
                fret_distance = abs(position[1] - move[0][1])
                string_distance = abs(position[0] - move[0][0])
                octave_difference = note[current].octave_differences[fret_position_index]
                fret = position[1]
                string = position[0]
                cumulative_cost = move[1] + cost_function(fret_distance, string_distance,octave_difference, fret, string, disliked_string_list, preferred_fret)
                if cumulative_cost < current_best_cost:
                    current_best_cost = cumulative_cost
                    best_way = move#stores the psoition with the least cost to get to the current position
            
            key = (position, current)         
            position_paths[key] = (best_way[0], current-1)
            temp_move_list.append((position, current_best_cost))
            fret_position_index += 1
        recent_moves = temp_move_list.copy()
    tab_solution = []
    lowest_cost = float("inf")
    for move in recent_moves: 
        if move[1] < lowest_cost:
            lowest_cost = move[1]
            key = (move[0], len(note)-1)
    tab_solution.append(key[0])
    while position_paths[key] != "None":
        previous_position = position_paths[key]
        tab_solution.append(previous_position[0])
        key = previous_position
    tab_solution = tab_solution[::-1]
    end_time = time.perf_counter()
    dynamic_programming_time = end_time - start_time
    return tab_solution, dynamic_programming_time

def generate_ascii_tab(tab_solution):
    tabs = {
        "6" : "(6)-",
        "5" : "(5)-",
        "4" : "(5)-",
        "3" : "(3)-",
        "2" : "(2)-",
        "1" : "(1)-"
        
}
    for note in tab_solution:
        current_string = note[0]
        fret = note[1]
        for string in range(1,7):
            if current_string == string:
                tabs[str(string)] = tabs[str(string)] +  str(fret) + "-"
            else:
                if fret > 9:
                    tabs[str(string)] = tabs[str(string)] +  "---"
                else:
                    tabs[str(string)] = tabs[str(string)] +  "--"

    ascii_tab = f'''{tabs["6"]}
{tabs["5"]}
{tabs["4"]}
{tabs["3"]}
{tabs["2"]}
{tabs["1"]}
'''
    return ascii_tab

def generate_ergonometric_metrics(tab_solution, preferred_fret):
    total_string_jump_length = 0
    total_fret_jump_size = 0
    max_string_jump = 0
    max_fret_jump = 0
    diagonal_counter = 0
    same_string_time = 0
    for x in range(len(tab_solution)-1):
        string_jump = abs(tab_solution[x][0] -tab_solution[x+1][0])
        total_string_jump_length += string_jump
        fret_jump = abs(tab_solution[x][1] -tab_solution[x+1][1])
        total_fret_jump_size += fret_jump
        if max_string_jump < string_jump:
            max_string_jump = string_jump
        if max_fret_jump < fret_jump:
            max_fret_jump = fret_jump
        if string_jump == fret_jump and fret_jump == 1:
            diagonal_counter += 1
        if string_jump == 0:
            same_string_time += 1
    min_fret = float("inf")
    max_fret = - min_fret
    for solution in tab_solution:
        if solution[1] > max_fret:
            max_fret = solution[1]
        if solution[1] < min_fret:
            min_fret = solution[1]
    fret_range = max_fret - min_fret
    user_preferrence_variance = ((min_fret + max_fret)/2) - preferred_fret

    average_string_jump = total_string_jump_length/(len(tab_solution)-1)
    average_fret_jump = total_fret_jump_size/(len(tab_solution)-1)
    diagonal_to_movement_ratio = diagonal_counter/(len(tab_solution)-1)#measures ratio of 1 by 1 diagonal moves to total movement
    same_string_ratio = same_string_time/(len(tab_solution)-1)#measures string stability
    movement_cost = (average_string_jump**2 + average_fret_jump**2)**0.5 + 1.5*((max_fret_jump**2 + max_string_jump**2)**0.5) + 0.5 * fret_range
    smoothness_penalty = 1 - diagonal_to_movement_ratio
    string_instability_penalty = 1 - same_string_ratio
    user_preferrence_cost = user_preferrence_variance * 0.1
    ergonomic_cost = movement_cost + string_instability_penalty + smoothness_penalty - user_preferrence_cost
    ergonomic_score = round(100 - ergonomic_cost)
    return average_string_jump, average_fret_jump, max_string_jump, max_fret_jump, diagonal_to_movement_ratio, same_string_ratio, ergonomic_cost, ergonomic_score
    
def print_ergonomic_metrics(tab_solution, preferred_fret, optimization_time):
    average_string_jump, average_fret_jump, max_string_jump, max_fret_jump, diagonal_to_movement_ratio, same_string_ratio, ergonomic_cost, ergonomic_score = generate_ergonometric_metrics(tab_solution, preferred_fret)
    print(f'''
Average String Jump: {average_string_jump}
