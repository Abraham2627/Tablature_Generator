def extract_pitch_info(waveform, sample_rate):
    #This section uses librosa.pyin to obtain 3 arrays containing pitch,whether or not a pitch was detected, and the probility of accuracy stored in pitch_data, note_dtected and confidence respectively
    pitch_data, note_detected, confidence = librosa.pyin(
    waveform,
    fmin = 82.4, #minimum guitar pitch
    fmax = 1318.5, #maximum guitar pitch
    sr = sample_rate,
)
    return pitch_data, note_detected, confidence
def generate_midi_list(pitch_data):
    midi_num = []
    for pitch in pitch_data:
        try:
            midi_num.append(round((12 * math.log((pitch/440), 2))+69)) #formula for converting from pitch to midi numbers
        except:
            midi_num.append(-1)
    return midi_num
def generate_note_list(pitch_data, confidence, note_detected, midi_num):#add all frames to notevents, then create methods to calculate things like start time and use ooficial values and thresholds
    notes = []
    empty_list  = False
    silence_counter = 0
    for each in range(len(pitch_data)):
        if not empty_list and note_detected[each] == True: #using new_note allows the code to ensure that atleast one value is in the list before it starts comparing with previous values, preventing errors while simultaneously allowing making of new note after silence or change in note
            note_event = NoteEvents(note_detected[each], pitch_data[each], each, midi_num[each])
            note_event.add_frame_index(each)
            note_event.add_confidence(confidence[each])
            notes.append(note_event)
            empty_list = True

        elif note_detected[each] == True: #using elif because else would include when note_detected = false
            if midi_num[each] == midi_num[each-1] and silence_counter < 18:#if current note is the same as last one
                notes[len(notes)-1].add_frame_index(each)#adds current frame index to list of frame indexes containing the same note in a contiguous run
                notes[len(notes)-1].add_confidence(confidence[each])#adds current note confidence to use to calculate average confidence

            elif (midi_num[each] != midi_num[each-1]) or (midi_num[each] == midi_num[each-1] and silence_counter >= 18): # current note != previous note or there is long enoigh silence such that a note has to be replayed
                note_event = NoteEvents(note_detected[each], pitch_data[each], each, midi_num[each])
                note_event.add_frame_index(each)
                note_event.add_confidence(confidence[each])
                notes.append(note_event)

            silence_counter = 0

        elif note_detected[each] == False :
            silence_counter += 1
    return notes

def generate_note_duration_and_confidence_lists(notes, sample_rate):
    note_duration_list = []
    note_confidence_list = []
    for each_note in notes:
        each_note.calc_duration(sample_rate)
        note_duration_list.append(each_note.duration)
        each_note.calc_average_confidence()
        note_confidence_list.append(each_note.confidence)
    return note_duration_list, note_confidence_list

def generate_valid_note_list(notes, minimum_duration, minimum_confidence, sample_rate):#makes list of all valid notes to be used for fretboard mapping and tab generation
    note = []
    for each_note in notes:
        if each_note.duration < minimum_duration or each_note.midi_num < 0 or each_note.confidence < minimum_confidence: #remove very short notes/low confidence notes which are likely noise and also removeany note with no or a wrong midi number that potentially still made it into the list
            continue

        else:  ## add attributes like start_time now that all NoteEvents and their basic required details have been made then add that to an official note_list
            each_note.calc_start_time(sample_rate)
            each_note.determine_note_value()
            note.append(each_note)
    return note

