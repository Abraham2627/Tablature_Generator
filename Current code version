musical_notes = ["C", "C#", "D", "D#", "E", "F", "F#", "G", "G#", "A", "A#", "B"]
class NoteEvents:
    def __init__(self, detected, pitch, frame_index, midi):
        self.detected = detected
        self.pitch = pitch
        self.frame_indexes = []
        self.start_time = 0
        self.duration = 0
        self.midi_num = midi
        self.note_name = ""
        self.confidence_list = []
        self.confidence = 0
        self.fret_positions = []
        self.fret_position_to_midi_correspondence= []
        self.octave_differences = []

    def add_frame_index(self, frame_index):
        self.frame_indexes.append(frame_index)
        
    def calc_start_time(self):
        self.start_time = (512 * (self.frame_indexes[0]))/sample_rate

    def calc_duration(self):
        self.duration = (512 * len(self.frame_indexes))/sample_rate

    def determine_note_value(self):
        note_value = musical_notes[self.midi_num % 12] #uses modulo to calculate the note
        octave = (self.midi_num // 12)-1 #-1 is used because smallest midi number, 0, corresponds to 'C-1'
        self.note_name = f"{note_value}{octave}"

    def add_confidence(self, confidence):
        self.confidence_list.append(confidence)
    def calc_average_confidence(self): #calculates the average confidence of a note
        total = 0
        try: # handles any case where confidence is not a proper numerical value
            for x in self.confidence_list:
                total += x
            self.confidence = total/len(self.confidence_list)

        except:
            self.confidence = 0

    def find_all_fret_positions(self, selected_strings, min_fret, max_fret, guitar_strings):
        overall_min_fret_midi = selected_strings[0] + min_fret #minimum midinote in playable region
        overall_max_fret_midi = selected_strings[len(selected_strings)-1] + max_fret #maximum midinote in playable region
        possible_note_midi_nums = [] #list of all octaves of a note in playable region
        temp_midi_num = self.midi_num # to avoid changing the actual midi number while adjusting the midi number used if the note isnt in the 4 by 7 area
        while not ((temp_midi_num >= overall_min_fret_midi) and (temp_midi_num <= overall_max_fret_midi)): #runs if temp_midi_num not in 4 by 7 area
            while temp_midi_num < overall_min_fret_midi:
                temp_midi_num += 12 #adds 12 to increment into range if below range
            while temp_midi_num > overall_max_fret_midi:
                temp_midi_num -= 12 #subs 12 to decrement into range if above range
        if abs(temp_midi_num - overall_min_fret_midi) <= abs(temp_midi_num - overall_max_fret_midi): # finds higher octaves if currently found midi_num is lowest in playable region
            while temp_midi_num <= overall_max_fret_midi:
                possible_note_midi_nums.append(temp_midi_num)
                temp_midi_num += 12

        elif abs(temp_midi_num - overall_max_fret_midi) <= abs(temp_midi_num - overall_min_fret_midi):# finds lower octaves if currently found midi_num is highest in playable region
            while temp_midi_num >= overall_min_fret_midi:
                possible_note_midi_nums.append(temp_midi_num)
                temp_midi_num -= 12

        else: #adds both ways to find octaves in both directions if note is in middle of range
            while temp_midi_num >= overall_min_fret_midi:
                possible_note_midi_nums.append(temp_midi_num)
                temp_midi_num -= 12
            temp_midi_num += 12
            while temp_midi_num <= overall_max_fret_midi:
                possible_note_midi_nums.append(temp_midi_num)
                temp_midi_num += 12
        possible_note_midi_nums = list(set(possible_note_midi_nums)) #set() removes any duplicates
            
         
                
        for string in selected_strings:#checks if note is playable in selected range on each string
            string_min_fret_midi = string + min_fret #minimum playable note on said string
            string_max_fret_midi = string +max_fret #maximum playable note on said string
            for possible_note in possible_note_midi_nums: #checks if each possible octave can be played in the playable region of that string
                if (possible_note >= string_min_fret_midi) and (possible_note <= string_max_fret_midi):#if in playable region
                    string_number = 6 - guitar_strings.index(string)
                    fret_number = possible_note - string
                    string_fret_pair = (string_number,fret_number)
                    self.fret_positions.append(string_fret_pair)
                    self.fret_position_to_midi_correspondence.append(possible_note)#appends to a fret...corespondence list the midi num of the corresponding fretposition just appended in order to use for determining octave difference
                    self.octave_differences.append(abs(self.midi_num - possible_note)/12)#appends to octave_differences list the octave difference for corresponding fret posiution

        

