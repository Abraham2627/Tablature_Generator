def cost_function(fret_distance, string_distance,octave_difference, fret, string, disliked_string_list, preferred_fret):
    distance_from_preferred_fret = abs(preferred_fret - fret)
    if string in disliked_string_list:
        disliked_string_penalty = 1.5
    else:
        disliked_string_penalty = 0
    cost = (1.5 * string_distance) + (1 * fret_distance) + (1.5 * octave_difference) + 0.2 * distance_from_preferred_fret + disliked_string_penalty 
    if fret_distance == string_distance == 1: #rewards 1 by 1 diagonal moves
        cost -= 1
    if string_distance == 0: #rewards lack of string changes
        cost -= 1
    if string_distance >= 2:
        cost += ((string_distance -1) * 0.5)
    
    
    return cost

